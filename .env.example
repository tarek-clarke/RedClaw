# RedClaw Stealth Configuration (Local Settings)
# Only edit the real .env file. Do NOT push .env to GitHub.

# 💡 TIP: You can use your Tailscale IP here if running remotely!
LM_STUDIO_HOST=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio

# 💡 TIP: Model names must match what you have loaded in LM Studio.
# DEFAULT_MODEL_VISION=openai/gpt-oss-20b

# 💡 TIP: Set to True to skip final "Apply" button clicks for testing.
# DRY_RUN=False
